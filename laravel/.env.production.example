# ==================================================
# Configuration pour le serveur (hébergement mutualisé)
# ==================================================
# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais versionner le .env — ce fichier est un modèle
# ==================================================

APP_NAME="Mon Bar Associatif"
APP_ENV=production
APP_KEY=base64:GENERER_AVEC_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://votre-domaine.fr

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=votre-host-mysql
DB_PORT=3306
DB_DATABASE=votre_base_de_donnees
DB_USERNAME=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

MAIL_MAILER=smtp
MAIL_HOST=votre-serveur-smtp
MAIL_PORT=465
MAIL_USERNAME=votre@email.fr
MAIL_PASSWORD=votre_mot_de_passe_email
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=votre@email.fr
MAIL_FROM_NAME="Mon Bar Associatif"
